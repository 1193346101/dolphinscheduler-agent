# DolphinScheduler Agent 环境变量配置
# 复制此文件为 .env 并填写实际值

# ============ LLM 配置（必须）============
LLM_API_KEY=your-api-key-here
LLM_API_URL=https://api.anthropic.com  # 或其他兼容 OpenAI 格式的 API
LLM_MODEL=claude-sonnet-4-6

# ============ 钉钉机器人（可选）============
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
DINGTALK_SECRET=xxx

# ============ 飞书机器人（可选）============
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
FEISHU_APP_ID=xxx
FEISHU_APP_SECRET=xxx

# ============ 日志存储 ============
LOG_RETENTION_DAYS=7
LOG_MAX_SIZE_MB=500
LOG_DIR=logs

# ============ 安全配置 ============
# 自动修复风险阈值（LOW/MEDIUM 可自动修复，HIGH/CRITICAL 需审批）
AUTO_FIX_MAX_RISK=MEDIUM
APPROVAL_TIMEOUT_MINUTES=30

# ============ Spark History Server（全局默认）============
SPARK_HISTORY_URL=http://spark-history:18088
SPARK_HISTORY_TIMEOUT=30

# ============ YARN ResourceManager（全局默认）============
YARN_RM_URL=http://yarn-rm:8088
YARN_RM_TIMEOUT=30

# ============ API 服务 ============
API_HOST=0.0.0.0
API_PORT=8080

# ============ 知识库 ============
KNOWLEDGE_BASE_DIR=knowledge_base

# ============ 项目配置文件 ============
PROJECTS_CONFIG_PATH=config/projects.yaml

# ============ 知识图谱配置 ============
# 代码仓库根路径（用于类名搜索）
CODE_ROOT_PATH=/path/to/code_root
# 图谱存储路径
GRAPH_STORAGE_PATH=data/graph

# ============ DolphinScheduler API（图谱扫描）============
DS_API_URL=http://ds-api:12345
DS_API_TOKEN=your-ds-api-token

# ============ 默认项目（Chat Agent）============
DEFAULT_PROJECT_CODE=your-default-project-code